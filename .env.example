# Application
APP_NAME=AgentAuth
ENVIRONMENT=development
DEBUG=false

# Database
# POSTGRES_* are used by docker-compose.prod.yml to initialise the container.
# DATABASE_URL and REDIS_URL are injected by docker-compose.prod.yml for production.
# For local development without Docker, uncomment and set them here:
# DATABASE_URL=postgresql+asyncpg://agentauth:agentauth_dev_password@localhost:5432/agentauth
# REDIS_URL=redis://localhost:6379/0
POSTGRES_DB=agentauth
POSTGRES_USER=agentauth
POSTGRES_PASSWORD=your-db-password-here

# Security
SECRET_KEY=your-secret-key-here
# Dedicated AES key for encrypting private signing keys at rest.
# Must differ from SECRET_KEY in production — generate: openssl rand -hex 32
SIGNING_KEY_ENCRYPTION_KEY=your-signing-key-encryption-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT issuer URL — must match the public base URL of this service
ISSUER_URL=https://agentauth.example.com

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["*"]

# Bootstrap / root-agent self-registration
# Required in the X-Bootstrap-Token header for /agents/bootstrap and /agents/quickstart.
# Leave empty only for open local development; always set in production.
# Generate: openssl rand -hex 32
BOOTSTRAP_TOKEN=

# Admin (platform operators only — not agent auth)
# Required for GET /api/v1/stats and GET /api/v1/audit/events
ADMIN_API_KEY=your-admin-api-key-here

# Rate limiting (sliding window, all counts are per-agent or per-IP)
# RATE_LIMIT_TOKEN_REQUESTS=30
# RATE_LIMIT_API_REQUESTS=300
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_BOOTSTRAP_REQUESTS=5

# Backup
# BACKUP_DIR: local directory where backup files are stored (must be writable)
BACKUP_DIR=/home/admin/agentauth/backups
# BACKUP_REMOTE: rclone remote path for offsite copy; leave empty to skip
# Example: r2:agentauth-backups  (Cloudflare R2)
# Example: b2:agentauth-backups  (Backblaze B2)
# Example: s3:my-bucket/agentauth-backups  (AWS S3)
BACKUP_REMOTE=

# Grafana
GRAFANA_PASSWORD=your-password-here
